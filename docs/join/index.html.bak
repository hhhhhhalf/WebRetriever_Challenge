<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="../static/images/favicon.png">
  <link rel="apple-touch-icon" href="../static/images/apple-touch-icon.png">
  <title>终端注册 — WebRetriever Challenge 2026</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    :root{--primary:#2563eb;--primary-dark:#1d4ed8;--primary-light:#eff6ff;--accent:#0891b2;--accent-light:#ecfeff;--gold:#f59e0b;--gold-light:#fffbeb;--bg:#fff;--bg-alt:#f8fafc;--text:#0f172a;--text-2:#334155;--text-3:#64748b;--text-4:#94a3b8;--border:#e2e8f0;--radius:14px;}
    *{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:'Inter','Noto Sans SC',-apple-system,sans-serif;color:var(--text);line-height:1.7;background:var(--bg);}

    /* LANGUAGE */
    body.lang-zh [data-lang=en]{display:none !important;}
    body.lang-en [data-lang=zh]{display:none !important;}
    .lang-btn{position:fixed;bottom:24px;right:24px;z-index:9999;background:var(--primary);color:white;border:none;width:48px;height:48px;border-radius:50%;cursor:pointer;font-size:.85em;font-weight:700;box-shadow:0 4px 16px rgba(0,0,0,.2);transition:all .2s;display:flex;align-items:center;justify-content:center;}
    .lang-btn:hover{transform:scale(1.08);}

    /* NAV */
    .nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,.96);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid rgba(0,0,0,.04);}
    .nav-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:54px;}
    .nav-brand{text-decoration:none;display:flex;align-items:center;gap:8px;font-weight:700;font-size:.95em;color:var(--text-3);}
    .nav-brand img{height:30px;width:30px;border-radius:50%;object-fit:cover;}
    .nav-links{display:flex;align-items:center;gap:4px;}
    .nav-links a{color:var(--text-3);text-decoration:none;font-size:.8em;font-weight:600;padding:6px 10px;line-height:1.5;display:flex;align-items:center;border-radius:6px;transition:all .2s;}
    .nav-links a:hover{color:var(--primary);background:var(--primary-light);}
    .nav-links a.active{color:var(--primary);background:var(--primary-light);}
    .nav-dropdown{position:relative;display:flex;align-items:center;}
    .nav-dropdown-toggle{color:var(--text-3);text-decoration:none;font-size:.8em;font-weight:600;padding:6px 10px;line-height:1.5;border-radius:6px;transition:all .2s;cursor:pointer;background:none;border:none;font-family:inherit;display:flex;align-items:center;gap:4px;}
    .nav-dropdown-toggle:hover,.nav-dropdown.is-open .nav-dropdown-toggle{color:var(--primary);background:var(--primary-light);}
    .nav-dropdown-toggle .arrow{font-size:.6em;transition:transform .2s;}
    .nav-dropdown.is-open .arrow{transform:rotate(180deg);}
    .nav-dropdown-menu{display:none;position:absolute;top:100%;left:0;background:white;border-radius:10px;box-shadow:0 6px 24px rgba(0,0,0,.1);border:1px solid var(--border);padding:6px;padding-top:10px;min-width:140px;z-index:100;}
    .nav-dropdown.is-open .nav-dropdown-menu{display:flex;flex-direction:column;}
    .nav-dropdown-menu a{color:var(--text-3);text-decoration:none;font-size:.8em;font-weight:500;padding:7px 12px;border-radius:6px;transition:all .2s;white-space:nowrap;display:flex;align-items:center;gap:6px;}
    .nav-dropdown-menu a:hover,.nav-dropdown-menu a.active{color:var(--primary);background:var(--primary-light);}
    @media(min-width:601px){.nav-dropdown:hover .nav-dropdown-menu{display:flex;flex-direction:column;}.nav-dropdown:hover .nav-dropdown-toggle{color:var(--primary);background:var(--primary-light);}.nav-dropdown:hover .arrow{transform:rotate(180deg);}}
    .nav-burger{display:none;cursor:pointer;background:none;border:none;font-size:1.2em;color:var(--text-3);padding:8px;}
    @media(max-width:900px){
      .nav-links{display:none;position:absolute;top:54px;left:0;right:0;background:white;flex-direction:column;padding:8px 16px;box-shadow:0 4px 16px rgba(0,0,0,.08);}
      .nav-links.is-open{display:flex;}
      .nav-links a{padding:10px 12px;font-size:.9em;}
      .nav-burger{display:block;}
    }

    /* PAGE */
    .page-header{background:linear-gradient(150deg,#0f2a4a 0%,#1e40af 45%,#0369a1 100%);padding:120px 24px 60px;text-align:center;position:relative;}
    .page-header::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 25% 40%,rgba(255,255,255,.07) 0%,transparent 70%);}
    .page-header .inner{position:relative;z-index:1;}
    .page-header .badge{display:inline-block;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);color:white;padding:4px 16px;border-radius:20px;font-size:.82em;font-weight:500;margin-bottom:18px;}
    .page-header h1{color:white;font-size:2.2em;font-weight:800;margin-bottom:8px;}
    .page-header p{color:rgba(255,255,255,.75);font-size:1.05em;}

    .container{max-width:720px;margin:0 auto;padding:48px 24px 80px;}

    /* STEPS */
    .step{background:white;border:1px solid var(--border);border-radius:var(--radius);padding:28px;margin-bottom:20px;transition:box-shadow .2s;}
    .step:hover{box-shadow:0 4px 20px rgba(0,0,0,.06);}
    .step-head{display:flex;align-items:center;gap:12px;margin-bottom:12px;}
    .step-num{width:32px;height:32px;border-radius:50%;background:var(--primary);color:white;display:flex;align-items:center;justify-content:center;font-size:.85em;font-weight:700;flex-shrink:0;}
    .step-title{font-size:1.05em;font-weight:700;color:var(--text);}
    .step-body{color:var(--text-2);font-size:.92em;line-height:1.7;padding-left:44px;}

    .code-block{background:var(--bg-alt);border:1px solid var(--border);border-radius:10px;padding:36px 20px 16px;margin-top:12px;font-family:'SF Mono','Fira Code',monospace;font-size:.85em;color:var(--text);position:relative;overflow-x:auto;white-space:pre-wrap;word-break:break-all;line-height:1.6;}
    .copy-btn{position:absolute;top:8px;right:8px;background:var(--primary);color:white;border:none;border-radius:6px;padding:4px 10px;font-size:.75em;cursor:pointer;transition:all .2s;}
    .copy-btn:hover{background:var(--primary-dark);}
    .copy-btn.copied{background:#16a34a;}

    .note{margin-top:32px;padding:20px 24px;background:var(--gold-light);border:1px solid #fde68a;border-radius:var(--radius);color:var(--text-2);font-size:.9em;line-height:1.7;}
    .note strong{color:var(--text);}

    .footer-note{margin-top:32px;text-align:center;color:var(--text-4);font-size:.85em;}

    a{color:var(--primary);text-decoration:none;}
    a:hover{text-decoration:underline;}
  </style>
</head>
<body class="lang-zh">

<nav class="nav">
  <div class="nav-inner">
    <a href="../" class="nav-brand"><img src="../static/images/logo.jpg" alt=""> WebRetriever Challenge</a>
    <button class="nav-burger" id="navBurger" aria-label="menu"><i class="fas fa-bars"></i></button>
    <div class="nav-links" id="navLinks">
      <div class="nav-dropdown" id="navDropdownHome">        <button class="nav-dropdown-toggle">          <span data-lang="zh">赛事主页</span><span data-lang="en">Home</span> <i class="fas fa-chevron-down arrow"></i>        </button>        <div class="nav-dropdown-menu">          <a href="../" data-lang="zh"><i class="fas fa-home"></i> 主页</a><a href="../" data-lang="en"><i class="fas fa-home"></i> Home</a>          <a href="../#background" data-lang="zh"><i class="fas fa-globe"></i> 背景</a><a href="../#background" data-lang="en"><i class="fas fa-globe"></i> Background</a>          <a href="../#task" data-lang="zh"><i class="fas fa-bullseye"></i> 赛题</a><a href="../#task" data-lang="en"><i class="fas fa-bullseye"></i> Task</a>          <a href="../#evaluation" data-lang="zh"><i class="fas fa-chart-bar"></i> 评测</a><a href="../#evaluation" data-lang="en"><i class="fas fa-chart-bar"></i> Evaluation</a>          <a href="../#prizes" data-lang="zh"><i class="fas fa-trophy"></i> 奖项</a><a href="../#prizes" data-lang="en"><i class="fas fa-trophy"></i> Prizes</a>          <a href="../#schedule" data-lang="zh"><i class="fas fa-calendar-alt"></i> 赛程</a><a href="../#schedule" data-lang="en"><i class="fas fa-calendar-alt"></i> Schedule</a>          <a href="../#registration" data-lang="zh"><i class="fas fa-user-plus"></i> 报名</a><a href="../#registration" data-lang="en"><i class="fas fa-user-plus"></i> Register</a>          <a href="../#eligibility" data-lang="zh"><i class="fas fa-users"></i> 资格</a><a href="../#eligibility" data-lang="en"><i class="fas fa-users"></i> Eligibility</a>          <a href="../#organizers" data-lang="zh"><i class="fas fa-building"></i> 组织</a><a href="../#organizers" data-lang="en"><i class="fas fa-building"></i> Organizers</a>          <a href="../#resources" data-lang="zh"><i class="fas fa-link"></i> 资源</a><a href="../#resources" data-lang="en"><i class="fas fa-link"></i> Resources</a>          <a href="../#contact" data-lang="zh"><i class="fas fa-envelope"></i> 联系</a><a href="../#contact" data-lang="en"><i class="fas fa-envelope"></i> Contact</a>        </div>      </div>
      <div class="nav-dropdown" id="navDropdownGuide">
        <button class="nav-dropdown-toggle">
          <span data-lang="zh">评测指南</span><span data-lang="en">Guide</span> <i class="fas fa-chevron-down arrow"></i>
        </button>
        <div class="nav-dropdown-menu">
          <a href="../guide/" data-lang="zh"><i class="fas fa-book-open"></i> 指南首页</a><a href="../guide/" data-lang="en"><i class="fas fa-book-open"></i> Guide Home</a>
          <a href="../guide/#flow" data-lang="zh"><i class="fas fa-route"></i> 参赛流程</a><a href="../guide/#flow" data-lang="en"><i class="fas fa-route"></i> How It Works</a>
          <a href="../guide/#prepare" data-lang="zh"><i class="fas fa-rocket"></i> 如何备赛</a><a href="../guide/#prepare" data-lang="en"><i class="fas fa-rocket"></i> Prepare</a>
          <a href="../guide/#faq" data-lang="zh"><i class="fas fa-question-circle"></i> 常见问题</a><a href="../guide/#faq" data-lang="en"><i class="fas fa-question-circle"></i> FAQ</a>
        </div>
      </div>
      <a href="./" class="active" data-lang="zh">终端注册</a><a href="./" class="active" data-lang="en">Terminal Registration</a>
      <a href="../leaderboard/" data-lang="zh">比赛榜单</a><a href="../leaderboard/" data-lang="en">Competition Leaderboard</a>
    </div>
  </div>
</nav>

<div class="page-header">
  <div class="inner">
    <div class="badge">WebRetriever Challenge 2026</div>
    <h1 data-lang="zh">终端快速注册</h1>
    <h1 data-lang="en">Terminal Registration</h1>
    <p data-lang="zh">AI 辅助注册 — 1 分钟完成，无需浏览器操作</p>
    <p data-lang="en">AI-assisted registration — sign up in 1 minute, no browser needed</p>
  </div>
</div>

<div class="container">

  <div class="step">
    <div class="step-head">
      <div class="step-num">1</div>
      <div class="step-title" data-lang="zh">打开你的 AI 编程助手</div>
      <div class="step-title" data-lang="en">Open your AI coding assistant</div>
    </div>
    <div class="step-body">
      <span data-lang="zh">支持 Claude Code、ChatGPT Codex、Cursor 或任何有终端权限的 AI 助手。</span>
      <span data-lang="en">Claude Code, ChatGPT Codex, Cursor, or any AI agent with terminal access.</span>
    </div>
  </div>

  <div class="step">
    <div class="step-head">
      <div class="step-num">2</div>
      <div class="step-title" data-lang="zh">粘贴以下指令</div>
      <div class="step-title" data-lang="en">Paste this prompt</div>
    </div>
    <div class="step-body">
      <span data-lang="zh">复制并发送给你的 AI 助手。将邀请码替换为你收到的邀请码（来自赛事公告或报名确认邮件）：</span>
      <span data-lang="en">Copy and send to your AI assistant. Replace the invite code with yours (provided in the competition announcement or your registration confirmation email):</span>
      <div class="code-block" id="prompt-block">Help me register an Octo account and join a Space. Do everything in the terminal, no browser needed.

Invite code: &lt;YOUR_INVITE_CODE&gt;

Follow the guide at: https://github.com/Mininglamp-AI/WebRetriever_Challenge/main/docs/join/guide.md<button class="copy-btn" onclick="copyPrompt(this)">Copy</button></div>
    </div>
  </div>

  <div class="step">
    <div class="step-head">
      <div class="step-num">3</div>
      <div class="step-title" data-lang="zh">按提示操作</div>
      <div class="step-title" data-lang="en">Follow the prompts</div>
    </div>
    <div class="step-body">
      <span data-lang="zh">AI 会依次询问你的姓名、邮箱和密码，然后自动完成注册。你只需查收邮箱中的验证码。</span>
      <span data-lang="en">Your AI will ask for your name, email, and password, then handle the registration automatically. You'll just need to check your email for a verification code.</span>
    </div>
  </div>

  <div class="step">
    <div class="step-head">
      <div class="step-num">4</div>
      <div class="step-title" data-lang="zh">登录 Octo</div>
      <div class="step-title" data-lang="en">Log in to Octo</div>
    </div>
    <div class="step-body">
      <span data-lang="zh">AI 确认注册完成后，打开 Octo 用邮箱和密码登录，即可进入比赛空间：</span>
      <span data-lang="en">Once your AI confirms registration is complete, open Octo and log in with your email + password to enter the competition Space:</span>
      <p style="margin-top:10px;">
        <a href="https://im.deepminer.com.cn" target="_blank">🌐
          <span data-lang="zh">打开 Octo</span>
          <span data-lang="en">Open Octo</span>
        </a>
      </p>
    </div>
  </div>

  <div class="note">
    <strong data-lang="zh"><i class="fas fa-info-circle"></i> 提示</strong>
    <strong data-lang="en"><i class="fas fa-info-circle"></i> Note</strong><br>
    <span data-lang="zh">• 请使用未在其他平台用过的强密码<br>• 需要一个能收验证码的邮箱<br>• 邀请码来自赛事公告或你的报名渠道</span>
    <span data-lang="en">• Choose a strong password you haven't used elsewhere<br>• Requires an email that can receive verification codes<br>• Invite code is provided in the competition announcement or via your registration channel</span>
  </div>

  <div class="footer-note">
    <span data-lang="zh">遇到问题？请联系 <a href="mailto:WebRetrieverChallenge@mininglamp.com">WebRetrieverChallenge@mininglamp.com</a></span>
    <span data-lang="en">Questions? Contact <a href="mailto:WebRetrieverChallenge@mininglamp.com">WebRetrieverChallenge@mininglamp.com</a></span>
  </div>

</div>

<button class="lang-btn" id="langBtn" onclick="toggleLang()">EN</button>

<script>
function toggleLang(){
  var b=document.body,btn=document.getElementById('langBtn');
  var lang=b.classList.contains('lang-zh')?'en':'zh';
  b.className='lang-'+lang;
  btn.textContent=lang==='zh'?'EN':'中';
  document.documentElement.lang=lang;
  history.replaceState(null,'',lang==='en'?location.pathname:location.pathname+'?lang=zh');
  document.querySelectorAll('a[href*="../"]').forEach(function(a){var u=a.getAttribute('href').split('?')[0];a.href=lang==='en'?u:u+'?lang=zh';});
}
(function(){var lang=new URLSearchParams(location.search).get('lang')||'en';document.body.className='lang-'+lang;document.documentElement.lang=lang;document.getElementById('langBtn').textContent=lang==='zh'?'EN':'中';})();
function copyPrompt(btn){
  var block=document.getElementById('prompt-block');
  var text=block.innerText.replace('Copy','').trim();
  navigator.clipboard.writeText(text).then(function(){
    btn.textContent='✓';btn.classList.add('copied');
    setTimeout(function(){btn.textContent='Copy';btn.classList.remove('copied');},2000);
  });
}
document.getElementById('navBurger').addEventListener('click',function(){document.getElementById('navLinks').classList.toggle('is-open');});
// Guide dropdown
// Home dropdown
(function(){var hd=document.getElementById("navDropdownHome");if(!hd)return;var ht=hd.querySelector(".nav-dropdown-toggle");if(ht)ht.addEventListener("click",function(e){e.stopPropagation();document.querySelectorAll(".nav-dropdown").forEach(function(x){if(x!==hd)x.classList.remove("is-open");});hd.classList.toggle("is-open");});hd.querySelectorAll(".nav-dropdown-menu a").forEach(function(a){a.addEventListener("click",function(){hd.classList.remove("is-open");});});document.addEventListener("click",function(e){if(!hd.contains(e.target))hd.classList.remove("is-open");});})();
(function(){var gd=document.getElementById("navDropdownGuide");if(!gd)return;var gt=gd.querySelector(".nav-dropdown-toggle");if(gt)gt.addEventListener("click",function(e){e.stopPropagation();gd.classList.toggle("is-open");});gd.querySelectorAll(".nav-dropdown-menu a").forEach(function(a){a.addEventListener("click",function(){gd.classList.remove("is-open");});});document.addEventListener("click",function(e){if(!gd.contains(e.target))gd.classList.remove("is-open");});})();
</script>
</body>
</html>
