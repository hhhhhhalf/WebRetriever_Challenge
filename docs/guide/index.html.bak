<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>评测指南 — WebRetriever Challenge 2026</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/jpswalsh/academicons@1/css/academicons.min.css">
  <link rel="icon" type="image/png" href="../static/images/favicon.png">
  <link rel="apple-touch-icon" href="../static/images/apple-touch-icon.png">
  <style>
    :root{--primary:#2563eb;--primary-dark:#1d4ed8;--primary-light:#eff6ff;--accent:#0891b2;--accent-light:#ecfeff;--text:#0f172a;--text-2:#334155;--text-3:#64748b;--text-4:#94a3b8;--border:#e2e8f0;--bg:#fff;--bg-alt:#f8fafc;--radius:14px;}
    *{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:'Inter','Noto Sans SC',-apple-system,sans-serif;color:var(--text);line-height:1.7;background:var(--bg);}
    body.lang-zh [data-lang=en]{display:none !important;}
    body.lang-en [data-lang=zh]{display:none !important;}
    .lang-btn{position:fixed;bottom:24px;right:24px;z-index:9999;background:var(--primary);color:white;border:none;width:48px;height:48px;border-radius:50%;cursor:pointer;font-size:.85em;font-weight:700;box-shadow:0 4px 16px rgba(0,0,0,.2);transition:all .2s;display:flex;align-items:center;justify-content:center;}
    .lang-btn:hover{transform:scale(1.08);}
    .nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(255,255,255,.96);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid rgba(0,0,0,.04);}
    .nav-inner{max-width:1100px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:54px;}
    .nav-brand{text-decoration:none;display:flex;align-items:center;gap:8px;font-weight:700;font-size:.95em;color:var(--text-3);}
    .nav-brand img{height:30px;width:30px;border-radius:50%;object-fit:cover;}
    .nav-links{display:flex;align-items:center;gap:4px;}
    .nav-links a{color:var(--text-3);text-decoration:none;font-size:.8em;font-weight:600;padding:6px 12px;line-height:1.5;display:flex;align-items:center;border-radius:6px;transition:all .2s;}
    .nav-links a:hover{color:var(--primary);background:var(--primary-light);}
    .nav-links a.active{color:var(--primary);background:var(--primary-light);}
    .nav-dropdown{position:relative;display:flex;align-items:center;}
    .nav-dropdown-toggle{color:var(--text-3);text-decoration:none;font-size:.8em;font-weight:600;padding:6px 12px;border-radius:6px;transition:all .2s;cursor:pointer;background:none;border:none;font-family:inherit;display:flex;align-items:center;gap:4px;}
    .nav-dropdown-toggle:hover,.nav-dropdown.is-open .nav-dropdown-toggle{color:var(--primary);background:var(--primary-light);}
    .nav-dropdown-toggle .arrow{font-size:.6em;transition:transform .2s;}
    .nav-dropdown.is-open .arrow{transform:rotate(180deg);}
    .nav-dropdown-menu{display:none;position:absolute;top:100%;left:0;background:white;border-radius:10px;box-shadow:0 6px 24px rgba(0,0,0,.1);border:1px solid var(--border);padding:6px;padding-top:10px;min-width:140px;z-index:100;}
    .nav-dropdown.is-open .nav-dropdown-menu{display:flex;flex-direction:column;}
    .nav-dropdown-menu a{color:var(--text-3);text-decoration:none;font-size:.8em;font-weight:500;padding:7px 12px;border-radius:6px;transition:all .2s;white-space:nowrap;display:flex;align-items:center;gap:6px;}
    .nav-dropdown-menu a:hover,.nav-dropdown-menu a.active{color:var(--primary);background:var(--primary-light);}
    @media(min-width:601px){.nav-dropdown:hover .nav-dropdown-menu{display:flex;flex-direction:column;}.nav-dropdown:hover .nav-dropdown-toggle{color:var(--primary);background:var(--primary-light);}.nav-dropdown:hover .arrow{transform:rotate(180deg);}}
    @media(max-width:600px){.nav-links{gap:2px;}.nav-links a{font-size:.72em;padding:5px 6px;}}

    .page-container{max-width:860px;margin:0 auto;padding:80px 24px 60px;}
    .page-header{text-align:center;margin-bottom:48px;}
    .page-header .icon{font-size:2.5em;color:var(--primary);margin-bottom:16px;}
    .page-header h1{font-size:1.8em;font-weight:800;margin-bottom:8px;}
    .page-header .subtitle{color:var(--text-3);font-size:1em;}

    .guide-section{margin-bottom:44px;}
    .guide-section h2{font-size:1.2em;font-weight:700;margin-bottom:16px;padding-bottom:8px;border-bottom:2px solid var(--primary-light);display:flex;align-items:center;gap:8px;}
    .guide-section h2 i{color:var(--primary);font-size:.9em;}
    .guide-section p{color:var(--text-2);margin-bottom:12px;font-size:.95em;}
    .guide-section ul{color:var(--text-2);margin:0 0 16px 20px;font-size:.95em;}
    .guide-section li{margin-bottom:6px;}
    a.resource-link{color:var(--primary);text-decoration:none;font-weight:500;border-bottom:1px dashed var(--primary);transition:all .2s;}
    a.resource-link:hover{border-bottom-style:solid;}
    code{background:var(--bg-alt);border:1px solid var(--border);border-radius:4px;padding:1px 6px;font-size:.88em;font-family:'SF Mono','Fira Code',monospace;}

    .step-flow{display:flex;flex-direction:column;gap:0;margin:20px 0;}
    .step-item{display:flex;gap:16px;position:relative;padding-bottom:24px;}
    .step-item:last-child{padding-bottom:0;}
    .step-item:last-child .step-line{display:none;}
    .step-num{width:36px;height:36px;border-radius:50%;background:var(--primary);color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85em;flex-shrink:0;position:relative;z-index:1;}
    .step-line{position:absolute;left:17px;top:36px;bottom:0;width:2px;background:var(--primary-light);}
    .step-body{flex:1;padding-top:6px;}
    .step-body strong{font-size:.95em;}
    .step-body p{margin:4px 0 0;font-size:.88em;color:var(--text-3);}

    .info-card{background:var(--bg-alt);border:1px solid var(--border);border-radius:var(--radius);padding:20px 24px;margin:16px 0;}
    .info-card p{margin:0;font-size:.9em;}

    .faq-item{background:white;border:1px solid var(--border);border-left:3px solid var(--primary);border-radius:var(--radius);padding:18px 22px;margin-bottom:14px;}
    .faq-item h3{font-size:.95em;font-weight:700;color:var(--primary);margin:0 0 8px;}
    .faq-item p{color:var(--text-2);margin:0;font-size:.9em;}

    .res-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:16px;margin:20px 0;}
    .res-card{display:flex;flex-direction:column;align-items:center;text-align:center;padding:24px 12px;border-radius:var(--radius);border:1px solid var(--border);text-decoration:none;transition:all .2s;background:var(--bg);}
    .res-card:hover{border-color:var(--primary);box-shadow:0 4px 16px rgba(37,99,235,.1);transform:translateY(-2px);}
    .res-icon{width:48px;height:48px;border-radius:12px;background:var(--primary-light);color:var(--primary);display:flex;align-items:center;justify-content:center;font-size:1.3em;margin-bottom:12px;}
    .res-card .title{font-weight:600;font-size:.85em;color:var(--text);margin-bottom:4px;}
    .res-card .desc{font-size:.75em;color:var(--text-4);}
    @media(max-width:600px){.res-grid{grid-template-columns:repeat(2,1fr);}}

    .footer{text-align:center;padding:32px 24px;color:var(--text-4);font-size:.8em;border-top:1px solid var(--border);}
  </style>
</head>
<body class="lang-zh">

<nav class="nav">
  <div class="nav-inner">
    <a href="../" class="nav-brand"><img src="../static/images/logo.jpg" alt=""> WebRetriever Challenge</a>
    <div class="nav-links">
      <div class="nav-dropdown" id="navDropdownHome">        <button class="nav-dropdown-toggle" id="navDropToggleHome">          <span data-lang="zh">赛事主页</span><span data-lang="en">Home</span> <i class="fas fa-chevron-down arrow"></i>        </button>        <div class="nav-dropdown-menu" id="navDropMenuHome">          <a href="../" data-lang="zh"><i class="fas fa-home"></i> 主页</a><a href="../" data-lang="en"><i class="fas fa-home"></i> Home</a>          <a href="../#background" data-lang="zh"><i class="fas fa-globe"></i> 背景</a><a href="../#background" data-lang="en"><i class="fas fa-globe"></i> Background</a>          <a href="../#task" data-lang="zh"><i class="fas fa-bullseye"></i> 赛题</a><a href="../#task" data-lang="en"><i class="fas fa-bullseye"></i> Task</a>          <a href="../#evaluation" data-lang="zh"><i class="fas fa-chart-bar"></i> 评测</a><a href="../#evaluation" data-lang="en"><i class="fas fa-chart-bar"></i> Evaluation</a>          <a href="../#prizes" data-lang="zh"><i class="fas fa-trophy"></i> 奖项</a><a href="../#prizes" data-lang="en"><i class="fas fa-trophy"></i> Prizes</a>          <a href="../#schedule" data-lang="zh"><i class="fas fa-calendar-alt"></i> 赛程</a><a href="../#schedule" data-lang="en"><i class="fas fa-calendar-alt"></i> Schedule</a>          <a href="../#registration" data-lang="zh"><i class="fas fa-user-plus"></i> 报名</a><a href="../#registration" data-lang="en"><i class="fas fa-user-plus"></i> Register</a>          <a href="../#eligibility" data-lang="zh"><i class="fas fa-users"></i> 资格</a><a href="../#eligibility" data-lang="en"><i class="fas fa-users"></i> Eligibility</a>          <a href="../#organizers" data-lang="zh"><i class="fas fa-building"></i> 组织</a><a href="../#organizers" data-lang="en"><i class="fas fa-building"></i> Organizers</a>          <a href="../#resources" data-lang="zh"><i class="fas fa-link"></i> 资源</a><a href="../#resources" data-lang="en"><i class="fas fa-link"></i> Resources</a>          <a href="../#contact" data-lang="zh"><i class="fas fa-envelope"></i> 联系</a><a href="../#contact" data-lang="en"><i class="fas fa-envelope"></i> Contact</a>        </div>      </div>
      <div class="nav-dropdown" id="navDropdown">
        <button class="nav-dropdown-toggle" id="navDropToggle">
          <span data-lang="zh">评测指南</span><span data-lang="en">Guide</span> <i class="fas fa-chevron-down arrow"></i>
        </button>
        <div class="nav-dropdown-menu" id="navDropMenu">
          <a href="#flow" data-lang="zh"><i class="fas fa-route"></i> 参赛流程</a><a href="#flow" data-lang="en"><i class="fas fa-route"></i> How It Works</a>
          <a href="#prepare" data-lang="zh"><i class="fas fa-rocket"></i> 如何备赛</a><a href="#prepare" data-lang="en"><i class="fas fa-rocket"></i> Prepare</a>
          <a href="#faq" data-lang="zh"><i class="fas fa-question-circle"></i> 常见问题</a><a href="#faq" data-lang="en"><i class="fas fa-question-circle"></i> FAQ</a>
        </div>
      </div>
      <a href="../leaderboard/" data-lang="zh">比赛榜单</a><a href="../leaderboard/" data-lang="en">Leaderboard</a>
